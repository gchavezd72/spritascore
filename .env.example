# Resend API key (required in production for lead emails)
# Install: vercel integration add resend/resend-email
RESEND_API_KEY=re_xxxxxxxx

# Lead notification email (defaults shown)
LEAD_EMAIL_TO=info@spritascore.com
LEAD_EMAIL_FROM=SpritaScore <notifications@spritascore.com>

# Optional: CRM Webhook URL (HubSpot, Salesforce, Zapier, etc.)
# CRM_WEBHOOK_URL=https://hooks.example.com/spritascore-leads

# Optional: Google Search Console HTML tag verification (content value only)
# GOOGLE_SITE_VERIFICATION=your_verification_code

# GA4 measurement ID (configured in GTM container GTM-NDXVZKB3)
# G-PET5JPXKYG